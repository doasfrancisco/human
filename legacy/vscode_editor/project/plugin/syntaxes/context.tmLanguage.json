{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "context",
  "scopeName": "source.context",
  "patterns": [
    {
      "match": "^(\\S+)\\s*(—|–|--)\\s*(.+)$",
      "captures": {
        "1": {
          "name": "entity.name.section.context"
        },
        "2": {
          "name": "punctuation.separator.context"
        },
        "3": {
          "name": "markup.italic.context"
        }
      }
    },
    {
      "name": "string.quoted.double.context",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.context",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.context",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}
